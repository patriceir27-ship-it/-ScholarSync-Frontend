# ============================================================================
# CHANCEN FRONTEND ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env.local and fill in actual values
# .env.local is gitignored and should never be committed

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
# For production: https://api.chancen.example.com/api/v1

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

NEXT_PUBLIC_APP_NAME=Chancen International Rwanda
NEXT_PUBLIC_APP_DESCRIPTION=AI-Powered Admissions & Student Lifecycle Management

# ============================================================================
# BRANDING & DESIGN
# ============================================================================

# Chancen Brand Colors
NEXT_PUBLIC_BRAND_COLOR=#22C55E
NEXT_PUBLIC_BRAND_COLOR_DARK=#16A34A
NEXT_PUBLIC_BRAND_COLOR_LIGHT=#DCF7DC
NEXT_PUBLIC_ACCENT_BLUE=#3B82F6
NEXT_PUBLIC_ACCENT_ORANGE=#F97316

# Logo and assets
NEXT_PUBLIC_LOGO_URL=/images/chancen-logo.png
NEXT_PUBLIC_FAVICON_URL=/images/chancen-favicon.ico

# ============================================================================
# FEATURES & FLAGS
# ============================================================================

# Feature toggles
NEXT_PUBLIC_FEATURE_AI_SCREENING=true
NEXT_PUBLIC_FEATURE_RULE_ENGINE=true
NEXT_PUBLIC_FEATURE_ANALYTICS=true
NEXT_PUBLIC_FEATURE_ISA_TRACKING=true
NEXT_PUBLIC_FEATURE_STUDENT_MONITORING=true

# ============================================================================
# GOOGLE ANALYTICS & TRACKING
# ============================================================================

NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX # Optional

# ============================================================================
# AUTHENTICATION
# ============================================================================

# Token storage method: localStorage or sessionStorage
NEXT_PUBLIC_TOKEN_STORAGE=localStorage

# Token names
NEXT_PUBLIC_ACCESS_TOKEN_KEY=chancen_access_token
NEXT_PUBLIC_REFRESH_TOKEN_KEY=chancen_refresh_token

# ============================================================================
# PAGINATION
# ============================================================================

NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20
NEXT_PUBLIC_MAX_PAGE_SIZE=100

# ============================================================================
# FILE UPLOAD
# ============================================================================

NEXT_PUBLIC_MAX_FILE_SIZE_MB=10
NEXT_PUBLIC_ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Enable debug mode in development
NEXT_PUBLIC_DEBUG=false

# Mock API for development (when backend unavailable)
NEXT_PUBLIC_USE_MOCK_API=false

# ============================================================================
# PRODUCTION CHECKLIST
# ============================================================================
# Before deploying to production:
# 1. Set NEXT_PUBLIC_API_URL to production API endpoint
# 2. Disable NEXT_PUBLIC_DEBUG
# 3. Ensure all branding colors match brand guidelines
# 4. Verify all feature flags are appropriate
# 5. Set up Google Analytics if using tracking
# 6. Use proper logo and favicon URLs
